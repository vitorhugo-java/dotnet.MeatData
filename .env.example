# ──────────────────────────────────────────────────────────────
# MeatData Portal — environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# === Database (used by docker-compose and the API) ===
POSTGRES_DB=meatdata
POSTGRES_USER=meatdata_user
POSTGRES_PASSWORD=change_me
ConnectionStrings__Default=Host=localhost;Port=5432;Database=meatdata;Username=meatdata_user;Password=change_me

# === Redis (cache for external API responses) ===
ConnectionStrings__Redis=localhost:6379

# === FoodData Central (USDA) ===
# Free key, no card: https://api.data.gov/signup
FoodDataCentral__BaseUrl=https://api.nal.usda.gov/fdc/v1/
FoodDataCentral__ApiKey=YOUR_FDC_API_KEY
FoodDataCentral__DefaultPageSize=25
FoodDataCentral__CacheHoursForSearch=6
FoodDataCentral__CacheHoursForDetail=24

# === AgroAPI (Embrapa) — planned, not wired yet ===
# Portal: https://www.agroapi.cnptia.embrapa.br/store/
AgroApi__BaseUrl=https://api.cnptia.embrapa.br/
AgroApi__ClientId=YOUR_CLIENT_ID
AgroApi__ClientSecret=YOUR_CLIENT_SECRET

# === API host ===
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
