{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=meatdata;Username=meatdata_user;Password=meatdata_password"
  },
  "FoodDataCentral": {
    "BaseUrl": "https://api.nal.usda.gov/fdc/v1/",
    "ApiKey": "{{ via env var }}",
    "DefaultPageSize": 25,
    "CacheHoursForSearch": 6,
    "CacheHoursForDetail": 24
  }
}
